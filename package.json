{
  "name": "arch-score",
  "version": "0.1.0",
  "description": "Language-agnostic CLI that scores how well any project follows modern system-design standards, recommends folder structures, and emits AI-assistant guidance files.",
  "keywords": [
    "architecture",
    "system-design",
    "linter",
    "code-quality",
    "folder-structure",
    "12-factor",
    "ai-agents",
    "cli",
    "static-analysis"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "archscore": "dist/bin/archscore.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/bin/archscore.js",
    "selfscan": "node dist/bin/archscore.js .",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
