# arch-score runs FULLY OFFLINE by default — none of these are required.
# They are only read by the optional `--deep-ai` qualitative review, and only
# if you opt in. Your key/model is used directly and is never bundled.

# Which provider to use for --deep-ai: "anthropic" or "ollama".
# If unset, arch-score auto-detects (Anthropic if a key is present, else local Ollama).
ARCHSCORE_AI_PROVIDER=

# Anthropic path — your own API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=

# Model override. Defaults: "claude-sonnet-4-6" (anthropic) / "llama3.1" (ollama).
ARCHSCORE_AI_MODEL=

# Ollama host for the free local path. Defaults to http://localhost:11434.
OLLAMA_HOST=
